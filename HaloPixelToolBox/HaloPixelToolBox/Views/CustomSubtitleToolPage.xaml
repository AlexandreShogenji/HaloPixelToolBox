<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.CustomSubtitleToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Spacing="10" Margin="0,0,0,24">
            <TextBlock Text="自定义字幕" Style="{StaticResource TitleTextBlockStyle}"/>
            <controls:SettingsCard Header="字幕内容" Description="支持多行输入，发送时会按设备文本限制归一化">
                <TextBox Text="{x:Bind ViewModel.Text, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" MinWidth="420" MinHeight="100"/>
            </controls:SettingsCard>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <controls:SettingsCard Header="布局" Description="文本默认显示位置">
                    <ComboBox ItemsSource="{x:Bind ViewModel.LayoutNames}" SelectedIndex="{x:Bind ViewModel.SelectedLayoutIndex, Mode=TwoWay}"/>
                </controls:SettingsCard>
                <controls:SettingsCard Grid.Column="1" Header="滚动方向" Description="映射现有滚动布局协议">
                    <ComboBox ItemsSource="{x:Bind ViewModel.ScrollDirectionNames}" SelectedIndex="{x:Bind ViewModel.SelectedScrollDirectionIndex, Mode=TwoWay}"/>
                </controls:SettingsCard>
            </Grid>
            <controls:SettingsCard Header="速度" Description="预留参数，后续协议支持后直接适配">
                <Slider Value="{x:Bind ViewModel.Speed, Mode=TwoWay}" Minimum="1" Maximum="10" StepFrequency="1" Width="220"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="颜色" Description="预留参数，当前文本协议暂未公开颜色字段">
                <ComboBox ItemsSource="{x:Bind ViewModel.ColorNames}" SelectedIndex="{x:Bind ViewModel.SelectedColorIndex, Mode=TwoWay}"/>
            </controls:SettingsCard>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <controls:SettingsCard Header="闪烁" Description="预留参数">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.Blink, Mode=TwoWay}"/>
                </controls:SettingsCard>
                <controls:SettingsCard Grid.Column="1" Header="多行文本" Description="发送前将多行文本合并为设备可显示文本">
                    <ToggleSwitch IsOn="{x:Bind ViewModel.MultiLine, Mode=TwoWay}"/>
                </controls:SettingsCard>
            </Grid>
            <controls:SettingsExpander Header="定时发送" Description="延迟指定秒数后发送到字幕屏">
                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableTimedSend, Mode=TwoWay}"/>
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Header="延迟秒数" IsEnabled="{x:Bind ViewModel.EnableTimedSend, Mode=OneWay}">
                        <NumberBox Value="{x:Bind ViewModel.DelaySeconds, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Compact"/>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>
            <controls:SettingsCard Header="发送" Description="{x:Bind ViewModel.StatusMessage, Mode=OneWay}">
                <Button Content="发送到字幕屏" Command="{x:Bind ViewModel.SendCommand}" Style="{StaticResource AccentButtonStyle}"/>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
