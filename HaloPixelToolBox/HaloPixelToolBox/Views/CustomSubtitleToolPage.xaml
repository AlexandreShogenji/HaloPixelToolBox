<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.CustomSubtitleToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Spacing="12" Margin="0,0,0,24">
            <TextBlock Text="自定义字幕" Style="{StaticResource TitleTextBlockStyle}"/>

            <controls:SettingsCard Header="字幕内容" Description="{x:Bind ViewModel.TextLimitStatus, Mode=OneWay}">
                <Grid RowSpacing="8" MinWidth="420">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Text="{x:Bind ViewModel.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="输入要发送到字幕屏的文字"
                             TextWrapping="NoWrap"
                             AcceptsReturn="False"
                             MinWidth="420"/>
                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.TextLimitStatus, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </controls:SettingsCard>

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <controls:SettingsCard Header="布局"
                                       Description="未开启滚动时生效"
                                       IsEnabled="{x:Bind ViewModel.IsLayoutSelectionEnabled, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ToggleButton Content="左对齐"
                                      Command="{x:Bind ViewModel.SelectLeftLayoutCommand}"
                                      IsChecked="{x:Bind ViewModel.IsLeftLayoutSelected, Mode=OneWay}"
                                      MinWidth="82"
                                      Padding="12,8"/>
                        <ToggleButton Content="居中"
                                      Command="{x:Bind ViewModel.SelectCenterLayoutCommand}"
                                      IsChecked="{x:Bind ViewModel.IsCenterLayoutSelected, Mode=OneWay}"
                                      MinWidth="82"
                                      Padding="12,8"/>
                        <ToggleButton Content="右对齐"
                                      Command="{x:Bind ViewModel.SelectRightLayoutCommand}"
                                      IsChecked="{x:Bind ViewModel.IsRightLayoutSelected, Mode=OneWay}"
                                      MinWidth="82"
                                      Padding="12,8"/>
                    </StackPanel>
                </controls:SettingsCard>

                <controls:SettingsCard Grid.Column="1" Header="滚动方向" Description="选择向左/向右后会覆盖布局设置">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ToggleButton Content="不滚动"
                                      Command="{x:Bind ViewModel.SelectNoScrollCommand}"
                                      IsChecked="{x:Bind ViewModel.IsNoScrollSelected, Mode=OneWay}"
                                      MinWidth="82"
                                      Padding="12,8"/>
                        <ToggleButton Content="向左"
                                      Command="{x:Bind ViewModel.SelectScrollRightToLeftCommand}"
                                      IsChecked="{x:Bind ViewModel.IsScrollRightToLeftSelected, Mode=OneWay}"
                                      MinWidth="82"
                                      Padding="12,8"/>
                        <ToggleButton Content="向右"
                                      Command="{x:Bind ViewModel.SelectScrollLeftToRightCommand}"
                                      IsChecked="{x:Bind ViewModel.IsScrollLeftToRightSelected, Mode=OneWay}"
                                      MinWidth="82"
                                      Padding="12,8"/>
                    </StackPanel>
                </controls:SettingsCard>
            </Grid>

            <controls:SettingsExpander Header="定时发送" Description="延迟指定秒数后发送到字幕屏">
                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableTimedSend, Mode=TwoWay}"/>
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Header="延迟秒数" IsEnabled="{x:Bind ViewModel.EnableTimedSend, Mode=OneWay}">
                        <NumberBox Value="{x:Bind ViewModel.DelaySeconds, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Compact"/>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <controls:SettingsCard Header="发送" Description="{x:Bind ViewModel.StatusMessage, Mode=OneWay}">
                <Button Content="发送到字幕屏" Command="{x:Bind ViewModel.SendCommand}" Style="{StaticResource AccentButtonStyle}"/>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
