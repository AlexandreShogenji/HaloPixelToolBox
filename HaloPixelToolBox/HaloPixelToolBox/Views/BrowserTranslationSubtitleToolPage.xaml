<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.BrowserTranslationSubtitleToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Spacing="10" Margin="0,0,0,24">
            <TextBlock Text="浏览器实时翻译字幕" Style="{StaticResource TitleTextBlockStyle}"/>
            <controls:SettingsCard Header="浏览器进程" Description="后续捕获模块使用的目标进程名">
                <TextBox Text="{x:Bind ViewModel.BrowserProcessName, Mode=TwoWay}" MinWidth="240"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="翻译 API 地址" Description="预留在线翻译接口配置">
                <TextBox Text="{x:Bind ViewModel.TranslationApiEndpoint, Mode=TwoWay}" MinWidth="360"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="翻译 API Key" Description="预留密钥配置，当前不会发起真实网络请求">
                <PasswordBox Password="{x:Bind ViewModel.TranslationApiKey, Mode=TwoWay}" MinWidth="360"/>
            </controls:SettingsCard>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <controls:SettingsCard Header="源语言" Description="auto 表示自动检测">
                    <TextBox Text="{x:Bind ViewModel.SourceLanguage, Mode=TwoWay}"/>
                </controls:SettingsCard>
                <controls:SettingsCard Grid.Column="1" Header="目标语言" Description="翻译结果语言">
                    <TextBox Text="{x:Bind ViewModel.TargetLanguage, Mode=TwoWay}"/>
                </controls:SettingsCard>
            </Grid>
            <controls:SettingsCard Header="实时链路" Description="{x:Bind ViewModel.StatusMessage, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="启动占位捕获" Command="{x:Bind ViewModel.StartCaptureCommand}" Style="{StaticResource AccentButtonStyle}"/>
                    <Button Content="停止" Command="{x:Bind ViewModel.StopCaptureCommand}"/>
                    <Button Content="发送示例" Command="{x:Bind ViewModel.SendSampleCommand}"/>
                </StackPanel>
            </controls:SettingsCard>
            <TextBlock Text="{x:Bind ViewModel.CapturedText, Mode=OneWay}" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Page>
