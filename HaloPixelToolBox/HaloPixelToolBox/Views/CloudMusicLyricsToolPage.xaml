<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.CloudMusicLyricsToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Spacing="10" Margin="0,0,0,24">
            <TextBlock Text="网易云歌词旧入口" Style="{StaticResource TitleTextBlockStyle}"/>
            <controls:SettingsCard Header="功能迁移" Description="多平台歌词字幕已迁移到“歌词字幕”页面，旧入口保留以兼容托盘与历史导航。">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap"/>
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
