<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.VideoSubtitleToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Spacing="10" Margin="0,0,0,24">
            <TextBlock Text="视频字幕" Style="{StaticResource TitleTextBlockStyle}"/>
            <controls:SettingsCard Header="PotPlayer 实时同步" Description="{x:Bind ViewModel.PotPlayerSyncStatus, Mode=OneWay}">
                <ToggleSwitch IsOn="{x:Bind ViewModel.IsPotPlayerSyncEnabled, Mode=TwoWay}"
                              OnContent="已启用"
                              OffContent="已禁用"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="PotPlayer 字幕输出文件" Description="PotPlayer 播放时实时写入的字幕文本文件路径">
                <Grid ColumnSpacing="8" MinWidth="420">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.PotPlayerSubtitleOutputPath, Mode=TwoWay}"
                             PlaceholderText="填写 PotPlayer 字幕输出 txt 路径"/>
                    <Button Grid.Column="1"
                            Content="重新同步"
                            Command="{x:Bind ViewModel.RestartPotPlayerSyncCommand}"/>
                </Grid>
            </controls:SettingsCard>
            <controls:SettingsCard Header="视频文件" Description="本地视频路径，用于记录同步来源">
                <TextBox Text="{x:Bind ViewModel.VideoPath, Mode=TwoWay}" PlaceholderText="选择本地视频文件路径" MinWidth="360"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="字幕文件" Description="支持 SRT / WebVTT 基础解析">
                <TextBox Text="{x:Bind ViewModel.SubtitlePath, Mode=TwoWay}" PlaceholderText="选择本地字幕文件路径" MinWidth="360"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="播放进度" Description="与视频播放器进度同步，单位秒">
                <NumberBox Value="{x:Bind ViewModel.PositionSeconds, Mode=TwoWay}" Minimum="0" SpinButtonPlacementMode="Compact"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="字幕控制" Description="{x:Bind ViewModel.StatusMessage, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="解析字幕" Command="{x:Bind ViewModel.ParseSubtitleCommand}" Style="{StaticResource AccentButtonStyle}"/>
                    <Button Content="发送当前字幕" Command="{x:Bind ViewModel.SendCurrentCueCommand}"/>
                    <Button Content="开始同步" Command="{x:Bind ViewModel.StartPlaybackCommand}"/>
                    <Button Content="停止" Command="{x:Bind ViewModel.StopPlaybackCommand}"/>
                </StackPanel>
            </controls:SettingsCard>
            <TextBlock Text="{x:Bind ViewModel.LoadedCueCount, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter='已加载字幕条数：(0)'}"/>
            <TextBox Text="{x:Bind ViewModel.PreviewText, Mode=OneWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="180" IsReadOnly="True"/>
        </StackPanel>
    </ScrollViewer>
</Page>
