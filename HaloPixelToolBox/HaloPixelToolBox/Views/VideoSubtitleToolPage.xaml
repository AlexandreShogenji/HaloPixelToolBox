<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.VideoSubtitleToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Spacing="10" Margin="0,0,0,24">
            <TextBlock Text="视频字幕" Style="{StaticResource TitleTextBlockStyle}"/>
            <controls:SettingsCard Header="PotPlayer 实时同步" Description="{x:Bind ViewModel.PotPlayerSyncStatus, Mode=OneWay}">
                <ToggleSwitch IsOn="{x:Bind ViewModel.IsPotPlayerSyncEnabled, Mode=TwoWay}"
                              OnContent="已启用"
                              OffContent="已禁用"/>
            </controls:SettingsCard>
            <controls:SettingsCard Header="字幕输出文件" Description="选择 PotPlayer 实时写入的字幕文件，支持 TXT / SRT / WebVTT / ASS / SSA / LRC / SUB">
                <Grid ColumnSpacing="8" MinWidth="420">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.PotPlayerSubtitleOutputPath, Mode=TwoWay}"
                             PlaceholderText="请选择字幕输出文件"
                             IsReadOnly="True"/>
                    <Button Grid.Column="1"
                            Content="选择文件"
                            Command="{x:Bind ViewModel.SelectSubtitleOutputFileCommand}"/>
                    <Button Grid.Column="2"
                            Content="重新同步"
                            Command="{x:Bind ViewModel.RestartPotPlayerSyncCommand}"/>
                </Grid>
            </controls:SettingsCard>
            <controls:SettingsCard Header="同步状态" Description="{x:Bind ViewModel.StatusMessage, Mode=OneWay}">
                <TextBlock Text="启用后会在 PotPlayer 播放时读取字幕文件内容变化，并自动发送到字幕屏。"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </controls:SettingsCard>
            <TextBox Text="{x:Bind ViewModel.PreviewText, Mode=OneWay}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="180" IsReadOnly="True"/>
        </StackPanel>
    </ScrollViewer>
</Page>
