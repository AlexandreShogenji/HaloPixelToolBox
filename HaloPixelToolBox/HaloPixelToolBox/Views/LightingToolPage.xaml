<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.LightingToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="LightingPanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="24"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="0,0,0,24">
            <TextBlock Text="灯光颜色" Style="{StaticResource TitleTextBlockStyle}"/>

            <Border Style="{StaticResource LightingPanelStyle}">
                <Grid ColumnSpacing="28" RowSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock Text="氛围灯" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="切换开关、灯效、颜色、速度和亮度会自动发送到设备。" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ToggleSwitch Header="开关" IsOn="{x:Bind ViewModel.AmbientEnabled, Mode=TwoWay}"/>
                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Text="灯效模式" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <RadioButtons ItemsSource="{x:Bind ViewModel.EffectNames}"
                                          SelectedIndex="{x:Bind ViewModel.AmbientEffectIndex, Mode=TwoWay}"
                                          MaxColumns="3"/>
                        </StackPanel>

                        <Grid ColumnSpacing="18" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8">
                                <TextBlock Text="RGB 彩虹色板" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ColorPicker Color="{x:Bind ViewModel.AmbientPickerColor, Mode=OneWay}"
                                             ColorChanged="AmbientColorPicker_ColorChanged"
                                             IsAlphaEnabled="False"
                                             IsMoreButtonVisible="False"
                                             MinWidth="320"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="10">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <NumberBox Header="红(R)" Value="{x:Bind ViewModel.AmbientRed, Mode=TwoWay}" Minimum="0" Maximum="255" SpinButtonPlacementMode="Compact"/>
                                    <NumberBox Grid.Column="1" Header="绿(G)" Value="{x:Bind ViewModel.AmbientGreen, Mode=TwoWay}" Minimum="0" Maximum="255" SpinButtonPlacementMode="Compact"/>
                                    <NumberBox Grid.Column="2" Header="蓝(B)" Value="{x:Bind ViewModel.AmbientBlue, Mode=TwoWay}" Minimum="0" Maximum="255" SpinButtonPlacementMode="Compact"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <Border Width="44" Height="28" CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="{x:Bind ViewModel.AmbientPickerColor, Mode=OneWay}"/>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="{x:Bind ViewModel.AmbientHex, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="灯效速度" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <Slider Value="{x:Bind ViewModel.AmbientSpeed, Mode=TwoWay}" Minimum="1" Maximum="10" StepFrequency="1"/>
                                <TextBlock Text="亮度调节" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <RadioButtons ItemsSource="{x:Bind ViewModel.BrightnessNames}"
                                              SelectedIndex="{x:Bind ViewModel.AmbientBrightnessIndex, Mode=TwoWay}"
                                              MaxColumns="3"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource LightingPanelStyle}">
                <Grid ColumnSpacing="28" RowSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock Text="像素屏颜色" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBlock Text="调整像素屏主题颜色会立即发送，可选择同步氛围灯颜色。" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ToggleSwitch Header="同步氛围灯颜色" IsOn="{x:Bind ViewModel.SyncAmbientWithPixel, Mode=TwoWay}"/>
                    </StackPanel>

                    <Grid Grid.Column="1" ColumnSpacing="18" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="8">
                            <TextBlock Text="RGB 彩虹色板" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <ColorPicker Color="{x:Bind ViewModel.PixelPickerColor, Mode=OneWay}"
                                         ColorChanged="PixelColorPicker_ColorChanged"
                                         IsAlphaEnabled="False"
                                         IsMoreButtonVisible="False"
                                         MinWidth="320"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="10">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <NumberBox Header="红(R)" Value="{x:Bind ViewModel.PixelRed, Mode=TwoWay}" Minimum="0" Maximum="255" SpinButtonPlacementMode="Compact"/>
                                <NumberBox Grid.Column="1" Header="绿(G)" Value="{x:Bind ViewModel.PixelGreen, Mode=TwoWay}" Minimum="0" Maximum="255" SpinButtonPlacementMode="Compact"/>
                                <NumberBox Grid.Column="2" Header="蓝(B)" Value="{x:Bind ViewModel.PixelBlue, Mode=TwoWay}" Minimum="0" Maximum="255" SpinButtonPlacementMode="Compact"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="44" Height="28" CornerRadius="4">
                                    <Border.Background>
                                        <SolidColorBrush Color="{x:Bind ViewModel.PixelPickerColor, Mode=OneWay}"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="{x:Bind ViewModel.PixelHex, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
