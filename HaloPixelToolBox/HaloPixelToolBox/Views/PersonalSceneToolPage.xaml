<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.PersonalSceneToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:scenes="using:HaloPixelToolBox.Core.Models.Scenes"
    xmlns:viewModels="using:HaloPixelToolBox.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <ScrollViewer>
            <StackPanel Spacing="14" Margin="0,0,0,24">
                <TextBlock Text="个性场景" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.SceneCountText, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <GridView ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          HorizontalAlignment="Stretch">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:PersonalSceneCategoryGroup">
                            <ToggleButton Click="CategoryButton_Click"
                                          Tag="{Binding}"
                                          IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                                          MinWidth="112"
                                          Padding="14,10"
                                          Content="{x:Bind Header}"/>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <GridView ItemsSource="{x:Bind ViewModel.SelectedScenes, Mode=OneWay}"
                          SelectionMode="None"
                          MaxHeight="900">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,12,12"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="scenes:PersonalSceneDefinition">
                            <Grid Width="520" Height="62">
                                <Button Click="SceneButton_Click"
                                        Tag="{Binding}"
                                        Padding="0"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Background="Transparent"
                                        HorizontalAlignment="Stretch">
                                    <Grid Width="520" Height="62" CornerRadius="6" Background="Black">
                                        <Image Source="{x:Bind PreviewSource, Mode=OneWay}" Stretch="UniformToFill"/>
                                        <Border Background="#F0FFB15A"
                                                CornerRadius="0,0,0,4"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Padding="8,3"
                                                Opacity="{x:Bind InUseBadgeOpacity, Mode=OneWay}">
                                            <TextBlock Text="使用中"
                                                       Foreground="Black"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </Button>
                                <Button Content="删除"
                                        Click="SceneDelete_Click"
                                        Tag="{Binding}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,6,6"
                                        Padding="8,2"
                                        FontSize="12"
                                        Opacity="{x:Bind DeleteButtonOpacity, Mode=OneWay}"
                                        IsHitTestVisible="{x:Bind DeleteButtonHitTestVisible, Mode=OneWay}"/>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <Border Visibility="{x:Bind ViewModel.CustomWorkbenchVisibility, Mode=OneWay}"
                        Padding="18"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="自定义图像资源" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            <TextBlock Text="拖入或选择 1 到 5 张 256x32 PNG 图像；1 张为静态资源，多张为动画序列。"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <GridView ItemsSource="{x:Bind ViewModel.CustomFrameSlots, Mode=OneWay}"
                                  SelectionMode="None">
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="Margin" Value="0,0,10,10"/>
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:CustomSceneFrameSlot">
                                    <StackPanel Spacing="8" Width="168">
                                        <Border AllowDrop="True"
                                                DragOver="CustomFrame_DragOver"
                                                Drop="CustomFrame_Drop"
                                                Tag="{Binding}"
                                                Height="64"
                                                CornerRadius="6"
                                                BorderThickness="1"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                Background="Black">
                                            <Grid>
                                                <Image Source="{x:Bind PreviewSource, Mode=OneWay}"
                                                       Stretch="UniformToFill"
                                                       Opacity="{x:Bind PreviewOpacity, Mode=OneWay}"/>
                                                <StackPanel HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Opacity="{x:Bind PlaceholderOpacity, Mode=OneWay}"
                                                            Spacing="2">
                                                    <TextBlock Text="{x:Bind Title}" TextAlignment="Center"/>
                                                    <TextBlock Text="拖入 PNG"
                                                               FontSize="12"
                                                               TextAlignment="Center"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Content="选择" Click="CustomFrameChoose_Click" Tag="{Binding}"/>
                                            <Button Content="清除" Click="CustomFrameClear_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Content="生成资源" Command="{x:Bind ViewModel.GenerateCustomSceneCommand}"/>
                            <TextBlock Text="{x:Bind ViewModel.CustomSceneGenerationStatus, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Grid Visibility="{x:Bind ViewModel.GeneratedCustomSceneVisibility, Mode=OneWay}"
                              ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Click="GeneratedCustomScene_Click"
                                    Padding="0"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="Transparent">
                                <Grid Width="360" Height="44" CornerRadius="6" Background="Black">
                                    <Image Source="{x:Bind ViewModel.GeneratedCustomScenePreviewSource, Mode=OneWay}"
                                           Stretch="UniformToFill"/>
                                    <Border Background="#F04CD964"
                                            CornerRadius="4,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Padding="8,2">
                                        <TextBlock Text="已就绪"
                                                   Foreground="Black"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Button>
                            <Button Grid.Column="1"
                                    Content="固定到列表"
                                    Command="{x:Bind ViewModel.PinGeneratedCustomSceneCommand}"
                                    VerticalAlignment="Center"/>
                            <Button Grid.Column="2"
                                    Content="删除资源"
                                    Command="{x:Bind ViewModel.DeleteGeneratedCustomSceneCommand}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Content="重新扫描" Command="{x:Bind ViewModel.ReloadScenesCommand}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#CC000000"
                Opacity="{x:Bind ViewModel.UploadOverlayOpacity, Mode=OneWay}"
                IsHitTestVisible="{x:Bind ViewModel.IsUploading, Mode=OneWay}"
                Padding="28"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="360">
            <StackPanel Spacing="14" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.UploadMessage, Mode=OneWay}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontSize="18"
                           Foreground="White"/>
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{x:Bind ViewModel.UploadProgressValue, Mode=OneWay}"
                             Width="320"
                             Height="8"/>
                <TextBlock Text="{x:Bind ViewModel.UploadProgressText, Mode=OneWay}"
                           TextAlignment="Center"
                           FontSize="14"
                           Foreground="#CCFFFFFF"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
