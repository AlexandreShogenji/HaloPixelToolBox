<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HaloPixelToolBox.Views.PersonalSceneToolPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:scenes="using:HaloPixelToolBox.Core.Models.Scenes"
    xmlns:viewModels="using:HaloPixelToolBox.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <ScrollViewer>
            <StackPanel Spacing="14" Margin="0,0,0,24">
                <TextBlock Text="个性场景" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.SceneCountText, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <GridView ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          HorizontalAlignment="Stretch">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:PersonalSceneCategoryGroup">
                            <ToggleButton Click="CategoryButton_Click"
                                          Tag="{Binding}"
                                          IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                                          MinWidth="112"
                                          Padding="14,10"
                                          Content="{x:Bind Header}"/>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <GridView ItemsSource="{x:Bind ViewModel.SelectedScenes, Mode=OneWay}"
                          SelectionMode="None"
                          MaxHeight="900">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,12,12"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="scenes:PersonalSceneDefinition">
                            <Button Click="SceneButton_Click"
                                    Tag="{Binding}"
                                    Padding="0"
                                    BorderThickness="1"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch">
                                <Grid Width="520" Height="62" CornerRadius="6" Background="Black">
                                    <Image Source="{x:Bind PreviewSource, Mode=OneWay}" Stretch="UniformToFill"/>
                                    <Border Background="#F0FFB15A"
                                            CornerRadius="0,0,0,4"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Padding="8,3"
                                            Opacity="{x:Bind InUseBadgeOpacity, Mode=OneWay}">
                                        <TextBlock Text="使用中"
                                                   Foreground="Black"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Content="重新扫描" Command="{x:Bind ViewModel.ReloadScenesCommand}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Background="#CC000000"
                Opacity="{x:Bind ViewModel.UploadOverlayOpacity, Mode=OneWay}"
                IsHitTestVisible="{x:Bind ViewModel.IsUploading, Mode=OneWay}"
                Padding="28"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="360">
            <StackPanel Spacing="14" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.UploadMessage, Mode=OneWay}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontSize="18"
                           Foreground="White"/>
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Value="{x:Bind ViewModel.UploadProgressValue, Mode=OneWay}"
                             Width="320"
                             Height="8"/>
                <TextBlock Text="{x:Bind ViewModel.UploadProgressText, Mode=OneWay}"
                           TextAlignment="Center"
                           FontSize="14"
                           Foreground="#CCFFFFFF"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
